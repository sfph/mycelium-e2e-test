# Matrix homeserver URL (e.g. the Synapse instance from compose.e2e.yaml)
MATRIX_HOMESERVER=http://localhost:8008

# Access token for an authenticated Matrix user.
# Obtain via the Synapse admin API or by logging in:
#   curl -s -X POST http://localhost:8008/_matrix/client/v3/login \
#     -H 'Content-Type: application/json' \
#     -d '{"type":"m.login.password","user":"main","password":"main-pass"}' \
#     | python3 -m json.tool
MATRIX_ACCESS_TOKEN=
